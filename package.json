{
    "name": "c64util",
    "version": "1.2.1",
    "description": "CLI utility to convert Commodore 64 disc/tape formats and images to WAV audio files, with interactive play mode",
    "author": "Shayan Ostadhassan <shayanoh@me.com>",
    "main": "dist/index.js",
    "bin": {
        "c64util": "dist/index.js"
    },
    "scripts": {
        "build": "tsc && chmod +x dist/index.js",
        "start": "node dist/index.js",
        "dev": "tsc && node dist/index.js",
        "clean": "rm -rf dist",
        "buildasm": "mkdir -p assets && cd c64turbo && 64tass -Wall -q --cbm-prg -o loader.prg -L loader.lst loader.asm && 64tass -Wall -q --cbm-prg -o loader_header.prg -L loader_header.lst loader_header.asm && 64tass -Wall -q --cbm-prg -o image_viewer.prg -L image_viewer.lst image_viewer.asm && cp loader.prg loader_header.prg image_viewer.prg ../assets/"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE",
        "assets"
    ],
    "exports": {
        ".": "./dist/index.js"
    },
    "keywords": [
        "c64",
        "commodore",
        "commodore64",
        "tape",
        "t64",
        "wav",
        "tap",
        "d64",
        "prg",
        "retro"
    ],
    "license": "MIT",
    "dependencies": {
        "blessed": "^0.1.81",
        "chalk": "^5.6.2",
        "commander": "^12.1.0",
        "progress": "^2.0.3",
        "sharp": "^0.34.5",
        "speaker": "^0.5.5",
        "supports-terminal-graphics": "^0.1.0"
    },
    "type": "module",
    "devDependencies": {
        "@types/node": "^25.9.5",
        "@types/progress": "^2.0.7",
        "prettier": "^3.9.5",
        "typescript": "^7.0.2"
    },
    "packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882"
}
