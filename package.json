{
    "name": "c64util",
    "version": "1.1.1",
    "description": "CLI utility to convert Commodore 64 disc/tape formats to WAV audio files, with interactive play mode",
    "author": "Shayan Ostadhassan <shayanoh@me.com>",
    "main": "dist/index.js",
    "bin": {
        "c64util": "dist/index.js"
    },
    "scripts": {
        "build": "tsc && chmod +x dist/index.js",
        "start": "node dist/index.js",
        "dev": "tsc && node dist/index.js",
        "clean": "rm -rf dist"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE",
        "assets"
    ],
    "exports": {
        ".": "./dist/index.js"
    },
    "keywords": [
        "c64",
        "commodore",
        "commodore64",
        "tape",
        "t64",
        "wav",
        "tap",
        "d64",
        "prg",
        "retro"
    ],
    "license": "MIT",
    "dependencies": {
        "blessed": "^0.1.81",
        "chalk": "^5.3.0",
        "commander": "^12.0.0",
        "progress": "^2.0.3",
        "speaker": "^0.5.5"
    },
    "type": "module",
    "devDependencies": {
        "@types/node": "^25.6.0",
        "@types/progress": "^2.0.7",
        "typescript": "^6.0.3"
    }
}
